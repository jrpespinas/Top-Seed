{
  "name": "top-seed",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "pnpm --filter @top-seed/contracts build",
    "dev": "concurrently -n web,api -c cyan,magenta \"pnpm --filter @top-seed/web dev\" \"pnpm --filter @top-seed/api dev\"",
    "prebuild": "pnpm --filter @top-seed/contracts build",
    "build": "pnpm -r build",
    "pretest": "pnpm --filter @top-seed/contracts build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @top-seed/api db:generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
